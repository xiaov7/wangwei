flowchart LR
    A[检查发现问题] --> B[问题分类分级]
    B --> C[明确责任部门]
    C --> D[制定整改方案]
    D --> E[实施整改]
    E --> F[验证效果]
    F --> G{是否达标}
    G -->|是| H[归档与固化]
    G -->|否| I[退回继续整改]
    I --> E

    style A fill:#eef4fb,stroke:#1e3a5f,stroke-width:2px
    style B fill:#eef4fb,stroke:#1e3a5f
    style C fill:#fef5e7,stroke:#e67e22
    style D fill:#fef5e7,stroke:#e67e22
    style E fill:#f0f9f4,stroke:#27ae60,stroke-width:2px
    style F fill:#f0f9f4,stroke:#27ae60
    style G fill:#ffffff,stroke:#1e3a5f,stroke-width:2px
    style H fill:#e8f5ee,stroke:#27ae60,stroke-width:2px
    style I fill:#fdf2f2,stroke:#c0392b,stroke-width:2px
