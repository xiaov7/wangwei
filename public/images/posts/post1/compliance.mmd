        B1 --> C1[临时整改]
        C1 --> D1[通过检查]
        D1 --> E1[恢复常态]
        E1 --> F1[下次检查<br/>再突击]
        style A1 fill:#fdf2f2
        style B1 fill:#fdf2f2
        style C1 fill:#fdf2f2
        style D1 fill:#fdf2f2
        style E1 fill:#fdf2f2
        style F1 fill:#fdf2f2,stroke:#c0392b
    end

    subgraph 能力驱动["✅ 把合规当手段"]
        A2[检查通知] --> B2[差距分析]
        B2 --> C2[整改建设]
        C2 --> D2[通过检查]
        D2 --> E2[机制固化]
        E2 --> F2[持续提升]
        F2 -.->|下一轮| A2
        style A2 fill:#f0f9f4
        style B2 fill:#f0f9f4
        style C2 fill:#f0f9f4
        style D2 fill:#f0f9f4
        style E2 fill:#f0f9f4,stroke:#27ae60
        style F2 fill:#f0f9f4,stroke:#27ae60
    end
